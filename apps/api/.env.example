CYBERMAP_API_APP_NAME=CyberMap API
CYBERMAP_API_ENVIRONMENT=local
CYBERMAP_API_CORS_ORIGINS=http://localhost:3000
CYBERMAP_API_DATA_DIR=data

# Proveedores IA: las claves se configuran solo en el backend, nunca en el navegador.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# CYBERMAP_AI_CUSTOM_BASE_URL=
# CYBERMAP_AI_CUSTOM_API_KEY=

# El escaneo Nmap solo acepta IPs dentro de estas redes. Por defecto: loopback.
# CYBERMAP_NMAP_ALLOWED_NETWORKS=127.0.0.0/8,::1/128
