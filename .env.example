# CyberMap root environment example
# Do not store real secrets in this file.

# Local development
NODE_ENV=development

# Current MVP services
# Frontend-specific variables live in apps/web/.env.example
# Backend-specific variables live in apps/api/.env.example

# Future database support
# Not required by the current local JSON-storage MVP.
DATABASE_URL=postgresql://cybermap:cybermap_password@localhost:5432/cybermap

# Future AI provider support
# Leave empty unless a later module explicitly requires them.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Future local AI support
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LOCALAI_BASE_URL=http://localhost:8080/v1

# Future application secret
# Replace only in local/private env files, never in Git.
APP_SECRET=change_me_in_local_env
